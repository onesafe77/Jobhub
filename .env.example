# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Midtrans
# Set to 'production' on Railway, and 'sandbox' on Localhost
VITE_MIDTRANS_ENV=sandbox
VITE_MIDTRANS_CLIENT_KEY=your_midtrans_client_key
VITE_MIDTRANS_SERVER_KEY=your_midtrans_server_key

# Other APIs
VITE_OPENAI_API_KEY=your_openai_key
VITE_APIFY_TOKEN=your_apify_token
VITE_FIRECRAWL_API_KEY=your_firecrawl_key
GEMINI_API_KEY=your_gemini_key

# Production Domain (Used for Midtrans whitelisting spoofing)
VITE_PRODUCTION_DOMAIN=https://your-app.railway.app
